# Copy to production.tfvars and replace placeholder values.

environment   = "production"
project_name  = "codemaze"
aws_region    = "ap-south-1"
root_domain   = "example.com"
route53_zone_id = "Z0123456789ABCDEF"

# Production subdomains become:
# - API: api.example.com
# - Web: app.example.com
api_subdomain = "api"
web_subdomain = "app"

alert_email = "alerts@example.com"

vpc_cidr             = "10.41.0.0/16"
public_subnet_cidrs  = ["10.41.0.0/24", "10.41.1.0/24"]
private_subnet_cidrs = ["10.41.10.0/24", "10.41.11.0/24"]

# For the first bootstrap-only targeted apply, these can stay as placeholders.
# The GitHub production workflow replaces them with the real image tags later.
api_image    = "public.ecr.aws/docker/library/python:3.12-slim"
worker_image = "public.ecr.aws/docker/library/python:3.12-slim"

api_cpu              = 1024
api_memory           = 2048
worker_cpu           = 1024
worker_memory        = 2048
api_desired_count    = 2
worker_desired_count = 2

db_name               = "algorithm_puzzle"
db_username           = "algorithm_puzzle"
db_password           = "replace-with-production-db-password"
db_instance_class     = "db.t4g.small"
db_engine_version     = "16.13"
db_allocated_storage  = 40
db_backup_retention_period = 14
redis_node_type       = "cache.t4g.small"

django_secret_key            = "replace-with-production-django-secret-key"
google_oauth_client_id       = "replace-with-production-or-shared-google-client-id.apps.googleusercontent.com"
access_token_lifetime_minutes = 15
refresh_token_lifetime_days   = 7
