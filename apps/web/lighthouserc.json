{
  "ci": {
    "collect": {
      "numberOfRuns": 2,
      "startServerCommand": "npm run dev -- --host 127.0.0.1 --port 4173",
      "startServerReadyPattern": "Local:",
      "url": [
        "http://127.0.0.1:4173/",
        "http://127.0.0.1:4173/login",
        "http://127.0.0.1:4173/levels"
      ],
      "settings": {
        "preset": "desktop",
        "onlyCategories": [
          "performance",
          "accessibility"
        ]
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": [
          "error",
          {
            "minScore": 0.9
          }
        ],
        "categories:accessibility": [
          "error",
          {
            "minScore": 0.9
          }
        ]
      }
    }
  }
}
